# Bot Orchestrator Configuration
# Copy this file to .env and fill in your values

# OpenAI API Configuration (optional - only needed for API mode)
# ORCHESTRATOR_OPENAI_API_KEY=your_openai_api_key_here
# ORCHESTRATOR_PLANNER_MODEL=gpt-4o

# Tmux Configuration
ORCHESTRATOR_DEFAULT_TMUX_TARGET=dev:0.0

# Paths
ORCHESTRATOR_SESSIONS_DIR=sessions
ORCHESTRATOR_LOGS_DIR=logs
ORCHESTRATOR_PROMPTS_DIR=prompts
ORCHESTRATOR_PARTIALS_DIR=partials

# Browser Automation (for web mode)
ORCHESTRATOR_BROWSER_HEADLESS=false
ORCHESTRATOR_BROWSER_USER_DATA_DIR=browser_data
ORCHESTRATOR_BROWSER_TIMEOUT_MS=120000
# CDP endpoint for attaching to an already open Chrome session
# ORCHESTRATOR_CDP_URL=http://127.0.0.1:9222

# Loop Control
ORCHESTRATOR_MAX_STEPS=30
ORCHESTRATOR_STABLE_POLL_COUNT=4
ORCHESTRATOR_POLL_INTERVAL=3
ORCHESTRATOR_CAPTURE_TIMEOUT=3600
ORCHESTRATOR_CAPTURE_STALL_TIMEOUT=300

# Safety Settings
ORCHESTRATOR_DEFAULT_MODE=investigate
# Actions requiring approval (comma-separated)
ORCHESTRATOR_REQUIRE_APPROVAL_FOR=code_write,migration,restart,db_update,secret_change

# Recovery Settings
ORCHESTRATOR_MAX_RECOVERY_ATTEMPTS=3
ORCHESTRATOR_RECOVERY_BACKOFF_BASE=2

# History Settings
ORCHESTRATOR_HISTORY_SUMMARY_LENGTH=5

# Logging
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_LOG_TO_FILE=true
